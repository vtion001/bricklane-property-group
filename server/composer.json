{
  "name": "bpg/server",
  "description": "BPG API Server — CodeIgniter 4",
  "type": "project",
  "require": {
    "php": "^8.2",
    "codeigniter4/framework": "^4.5",
    "guzzlehttp/guzzle": "^7.8"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "mikey179/vfsstream": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  }
}
